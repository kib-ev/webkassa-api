#!/usr/bin/env php
<?php

declare(strict_types=1);

use WebKassa\Config\WebKassaConfig;
use WebKassa\Support\PeriodResolver;
use WebKassa\WebKassaManager;

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "CLI only.\n");
    exit(1);
}

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

foreach ($autoloadPaths as $path) {
    if (is_file($path)) {
        require $path;
        break;
    }
}

$options = getopt('', ['from:', 'to:', 'month:', 'output:', 'help']);

if (isset($options['help'])) {
    echo <<<HELP
WebKassa e-pos report export (standalone CLI)

Usage:
  export-epos --month=2026-06
  export-epos --from=2026-06-01 --to=2026-06-30
  export-epos --month=2026-06 --output=./report.xlsx

Environment:
  WEBKASSA_TOKEN or API_TOKEN
  WEBKASSA_MERCHANT_NAME or MERCHANT_NAME
  WEBKASSA_MERCHANT_UNP or MERCHANT_UNP
  WEBKASSA_TIMEZONE or TIMEZONE (default: Europe/Minsk)

HELP;
    exit(0);
}

$packageRoot = dirname(__DIR__);
if (is_file($packageRoot . '/.env') && class_exists(\Dotenv\Dotenv::class)) {
    \Dotenv\Dotenv::createImmutable($packageRoot)->safeLoad();
}

/**
 * @param list<string> $keys
 */
function envValue(array $keys, string $default = ''): string
{
    foreach ($keys as $key) {
        if (isset($_ENV[$key]) && $_ENV[$key] !== '') {
            return (string) $_ENV[$key];
        }

        $value = getenv($key);
        if ($value !== false && $value !== '') {
            return (string) $value;
        }
    }

    return $default;
}

$config = WebKassaConfig::fromArray([
    'token' => envValue(['WEBKASSA_TOKEN', 'API_TOKEN']),
    'base_url' => envValue(['WEBKASSA_BASE_URL'], 'https://cabinet.webkassa.by/api'),
    'timeout' => (int) envValue(['WEBKASSA_TIMEOUT'], '120'),
    'timezone' => envValue(['WEBKASSA_TIMEZONE', 'TIMEZONE'], 'Europe/Minsk'),
    'merchant' => [
        'name' => envValue(['WEBKASSA_MERCHANT_NAME', 'MERCHANT_NAME']),
        'unp' => envValue(['WEBKASSA_MERCHANT_UNP', 'MERCHANT_UNP']),
    ],
    'epos' => [
        'default_service' => envValue(['WEBKASSA_EPOS_DEFAULT_SERVICE', 'EPOS_SERVICE_DEFAULT'], 'Аренда'),
    ],
]);

if ($config->token === '') {
    fwrite(STDERR, "Error: WEBKASSA_TOKEN (or API_TOKEN) is not set.\n");
    exit(1);
}

try {
    $resolver = new PeriodResolver($config->timezone);
    [$from, $to] = $resolver->resolve($options);
} catch (InvalidArgumentException $e) {
    fwrite(STDERR, 'Error: ' . $e->getMessage() . PHP_EOL);
    exit(1);
}

$output = $options['output'] ?? $packageRoot . '/output/' . $from->format('Y-m') . '.xlsx';

$webkassa = new WebKassaManager($config);

echo sprintf(
    "Exporting e-pos report for %s — %s...\n",
    $from->format('d.m.Y'),
    $to->format('d.m.Y'),
);

$count = $webkassa->exportEposReport($from, $to, $output);

echo sprintf("Done: %d records → %s\n", $count, $output);
