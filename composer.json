{
    "name": "kib-ev/webkassa-api",
    "description": "PHP SDK для API WebKassa (Беларусь) с поддержкой Laravel",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/kib-ev/webkassa-api",
    "support": {
        "issues": "https://github.com/kib-ev/webkassa-api/issues",
        "source": "https://github.com/kib-ev/webkassa-api"
    },
    "keywords": [
        "webkassa",
        "laravel",
        "epos",
        "belarus",
        "cashbox",
        "api"
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "phpoffice/phpspreadsheet": "^2.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "WebKassa\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WebKassa\\WebKassaServiceProvider"
            ],
            "aliases": {
                "WebKassa": "WebKassa\\Facades\\WebKassa"
            }
        }
    },
    "bin": [
        "bin/export-epos"
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
